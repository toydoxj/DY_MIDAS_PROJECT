{
  "name": "midas-gen-nx-dashboard",
  "version": "1.3.3",
  "description": "MIDAS GEN NX API Dashboard",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "tree-kill": "^1.2.2"
  },
  "build": {
    "appId": "com.dongyang.midas-dashboard",
    "productName": "MIDAS Dashboard",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/backend",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "asar": false,
    "publish": {
      "provider": "github",
      "owner": "toydoxj",
      "repo": "DY_MIDAS_PROJECT"
    }
  }
}
