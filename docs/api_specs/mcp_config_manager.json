{
  "mcpServer": {
    "name": "Configuration & File Management",
    "version": "1.0.0",
    "description": "FormConfig 로드/저장, 설정 검증, 파일 관리",
    "baseUrl": "file:///config",
    "tools": [
      {
        "name": "load_form_config",
        "description": "FormConfig 파일 로드 (YAML/JSON 형식)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "config_path": {
              "type": "string",
              "description": "설정 파일 경로 (절대경로 권장)",
              "examples": [
                "./config.yaml",
                "/home/user/midas_config.json"
              ]
            },
            "format": {
              "type": "string",
              "enum": [
                "yaml",
                "json"
              ],
              "description": "파일 형식 (자동 감지 가능)"
            }
          },
          "required": [
            "config_path"
          ]
        },
        "example": {
          "request": {
            "config_path": "./config.yaml",
            "format": "yaml"
          },
          "response": {
            "success": true,
            "data": {
              "formConfig": {
                "projectName": "상업용 건물 구조 설계",
                "analysisType": "static"
              },
              "dyForm": {
                "geometry": {
                  "origin": [0, 0, 0],
                  "grid": [5, 5, 3.5]
                }
              }
            }
          }
        }
      },
      {
        "name": "validate_form_config",
        "description": "FormConfig 및 DY_Form 스키마 검증",
        "inputSchema": {
          "type": "object",
          "properties": {
            "config": {
              "type": "object",
              "description": "검증할 설정 객체",
              "properties": {
                "formConfig": {
                  "type": "object",
                  "properties": {
                    "projectName": {
                      "type": "string"
                    },
                    "analysisType": {
                      "type": "string",
                      "enum": [
                        "static",
                        "eigen",
                        "response_spectrum",
                        "time_history"
                      ]
                    }
                  },
                  "required": [
                    "projectName"
                  ]
                },
                "dyForm": {
                  "type": "object",
                  "properties": {
                    "geometry": {
                      "type": "object",
                      "required": ["origin"]
                    },
                    "section": {
                      "type": "array"
                    },
                    "material": {
                      "type": "array"
                    },
                    "load": {
                      "type": "array"
                    },
                    "boundary": {
                      "type": "array"
                    },
                    "view": {
                      "type": "array"
                    }
                  },
                  "required": [
                    "geometry",
                    "section",
                    "material",
                    "load",
                    "boundary",
                    "view"
                  ]
                }
              },
              "required": [
                "formConfig",
                "dyForm"
              ]
            },
            "strict": {
              "type": "boolean",
              "default": false,
              "description": "엄격한 검증 모드 (추가 필드 금지)"
            }
          },
          "required": [
            "config"
          ]
        },
        "example": {
          "request": {
            "config": {
              "formConfig": {
                "projectName": "Test Project"
              },
              "dyForm": {
                "geometry": {},
                "section": [],
                "material": [],
                "load": [],
                "boundary": [],
                "view": []
              }
            },
            "strict": false
          },
          "response": {
            "valid": true,
            "errors": [],
            "warnings": []
          }
        }
      },
      {
        "name": "save_form_config",
        "description": "FormConfig를 파일로 저장",
        "inputSchema": {
          "type": "object",
          "properties": {
            "config": {
              "type": "object",
              "description": "저장할 설정 객체"
            },
            "output_path": {
              "type": "string",
              "description": "저장 경로"
            },
            "format": {
              "type": "string",
              "enum": [
                "yaml",
                "json"
              ],
              "default": "yaml",
              "description": "저장 포맷"
            },
            "backup": {
              "type": "boolean",
              "default": true,
              "description": "기존 파일 백업 여부"
            }
          },
          "required": [
            "config",
            "output_path"
          ]
        }
      },
      {
        "name": "list_recent_configs",
        "description": "최근 사용한 설정 파일 목록 조회",
        "inputSchema": {
          "type": "object",
          "properties": {
            "config_dir": {
              "type": "string",
              "description": "설정 디렉토리 경로",
              "default": "./configs"
            },
            "limit": {
              "type": "integer",
              "default": 10,
              "description": "반환할 항목 수"
            },
            "pattern": {
              "type": "string",
              "description": "파일명 패턴 (정규식 가능)"
            }
          }
        },
        "example": {
          "response": {
            "success": true,
            "configs": [
              {
                "name": "config_001.yaml",
                "path": "./configs/config_001.yaml",
                "modified": "2025-03-24T10:30:00Z",
                "size": 2048
              }
            ]
          }
        }
      },
      {
        "name": "get_config_schema",
        "description": "FormConfig 및 DY_Form의 JSON Schema 조회",
        "inputSchema": {
          "type": "object",
          "properties": {
            "version": {
              "type": "string",
              "default": "1.0",
              "description": "스키마 버전"
            }
          }
        },
        "example": {
          "response": {
            "formConfigSchema": {
              "$schema": "http://json-schema.org/draft-07/schema#",
              "type": "object",
              "properties": {
                "projectName": {
                  "type": "string"
                },
                "analysisType": {
                  "type": "string",
                  "enum": [
                    "static",
                    "eigen",
                    "response_spectrum",
                    "time_history"
                  ]
                }
              }
            },
            "dyFormSchema": {
              "type": "object",
              "properties": {
                "geometry": {
                  "type": "object"
                },
                "section": {
                  "type": "array"
                }
              }
            }
          }
        }
      },
      {
        "name": "create_config_from_template",
        "description": "템플릿에서 새로운 설정 생성",
        "inputSchema": {
          "type": "object",
          "properties": {
            "template_name": {
              "type": "string",
              "enum": [
                "simple_beam",
                "multi_story_building",
                "bridge",
                "custom"
              ],
              "description": "템플릿 이름"
            },
            "project_name": {
              "type": "string",
              "description": "새 프로젝트 이름"
            },
            "overrides": {
              "type": "object",
              "description": "템플릿 기본값 오버라이드"
            }
          },
          "required": [
            "template_name",
            "project_name"
          ]
        },
        "example": {
          "request": {
            "template_name": "multi_story_building",
            "project_name": "My Building",
            "overrides": {
              "stories": 5,
              "bay_count": 3
            }
          },
          "response": {
            "success": true,
            "config": {}
          }
        }
      }
    ],
    "templates": {
      "simple_beam": {
        "name": "단순 보 모델",
        "description": "2점 지점의 단순 보 해석",
        "formConfig": {
          "projectName": "Simple Beam",
          "analysisType": "static"
        },
        "dyForm": {
          "geometry": {
            "origin": [0, 0, 0],
            "span": 10000
          }
        }
      },
      "multi_story_building": {
        "name": "다층 건물",
        "description": "중력 하중 및 횡력 해석",
        "formConfig": {
          "projectName": "Multi-Story Building",
          "analysisType": "static"
        }
      }
    },
    "fileManagement": {
      "supportedFormats": [
        "yaml",
        "json",
        "xml"
      ],
      "maxFileSize": 10485760,
      "autoBackup": true,
      "backupRetention": 5
    }
  }
}
